<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@android:color/transparent"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/editBackpackName"
            android:hint="Backpack Name"
            android:minHeight="48dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/editMaxVolume"
            android:hint="Max Volume (liters)"
            android:inputType="numberDecimal"
            android:minHeight="48dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/editMaxWeight"
            android:hint="Max Weight (kg)"
            android:inputType="numberDecimal"
            android:minHeight="48dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnSaveBackpack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Backpack"
            android:minHeight="48dp"
            android:layout_marginTop="20dp" />
    </LinearLayout>
</ScrollView>