<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@android:color/transparent"/>

        <!-- BASIC FIELDS -->
        <EditText
            android:id="@+id/editName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Gear Name"/>

        <EditText
            android:id="@+id/editBrand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Brand (optional)"/>

        <EditText
            android:id="@+id/editModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Model (optional)"/>

        <EditText
            android:id="@+id/editWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:inputType="numberDecimal"
            android:hint="Weight"/>

        <EditText
            android:id="@+id/editVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:inputType="numberDecimal"
            android:hint="Volume (liters)"/>

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerConditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- GEAR TYPE -->
        <TextView
            android:text="Gear Type"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"/>

        <Spinner
            android:id="@+id/spinnerGearType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- ========================= -->
        <!-- TENT SECTION -->
        <!-- ========================= -->
        <LinearLayout
            android:id="@+id/sectionTent"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp">

            <TextView
                android:text="Tent Capacity (people)"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/editTentCapacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>

            <CheckBox
                android:id="@+id/checkFourSeason"
                android:text="4-Season Tent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <CheckBox
                android:id="@+id/checkFreestanding"
                android:text="Freestanding Tent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- ========================= -->
        <!-- SLEEPING BAG SECTION -->
        <!-- ========================= -->
        <LinearLayout
            android:id="@+id/sectionSleepingBag"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp">

            <TextView
                android:text="Comfort Temperature (°)"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/editComfortTemp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>

            <TextView
                android:text="Extreme Temperature (°)"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/editExtremeTemp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>

            <TextView
                android:text="Insulation Type"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Spinner
                android:id="@+id/spinnerInsulation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>


        <!-- ========================= -->
        <!-- SLEEPING PAD SECTION -->
        <!-- ========================= -->
        <LinearLayout
            android:id="@+id/sectionSleepingPad"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp">

            <TextView
                android:text="R-Value"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/editRValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>

        </LinearLayout>


        <!-- ========================= -->
        <!-- WEATHER SECTION -->
        <!-- ========================= -->
        <LinearLayout
            android:id="@+id/sectionWeather"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp">

            <TextView
                android:text="Weather Suitability"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <CheckBox
                android:id="@+id/checkGoodForCold"
                android:text="Good for Cold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <CheckBox
                android:id="@+id/checkGoodForRain"
                android:text="Good for Rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <CheckBox
                android:id="@+id/checkGoodForSnow"
                android:text="Good for Snow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <CheckBox
                android:id="@+id/checkGoodForWind"
                android:text="Good for Wind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>


        <!-- ========================= -->
        <!-- CONDITION -->
        <!-- ========================= -->
        <TextView
            android:text="Condition"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"/>

        <Spinner
            android:id="@+id/spinnerCondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>


        <!-- ========================= -->
        <!-- NOTES -->
        <!-- ========================= -->
        <TextView
            android:text="Notes / Issues"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>

        <EditText
            android:id="@+id/editNotes"
            android:hint="e.g. leaks, broken zipper, missing stakes..."
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:padding="10dp"
            android:background="#EEEEEE"
            android:inputType="textMultiLine"/>


        <!-- ========================= -->
        <!-- SAVE BUTTON -->
        <!-- ========================= -->
        <Button
            android:id="@+id/btnSaveGear"
            android:text="Save Gear"
            android:minHeight="48dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>